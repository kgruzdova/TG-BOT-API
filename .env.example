# Токен Telegram-бота (получить у @BotFather)
BOT_TOKEN=your_bot_token_here

# Ключ API OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=your_openai_api_key_here

# Модель OpenAI (gpt-5-mini-2025-08-07, gpt-4o и т.д.)
OPENAI_MODEL=gpt-5-mini-2025-08-07

# Модель для видео (sora-2, sora-2-pro)
SORA_MODEL=sora-2

# Модель для изображений (gpt-image-1-mini, gpt-image-1, gpt-image-1.5)
IMAGE_MODEL=gpt-image-1-mini

# Максимум сообщений в истории диалога на пользователя
MAX_HISTORY_MESSAGES=10
